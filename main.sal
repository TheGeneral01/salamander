#[T_DEF][T_IDENTIFIER][T_LPAREN][T_DYN][T_IDENTIFIER][T_COMMA][T_DYN][T_IDENTIFIER][T_RPAREN][T_COLON]
#[T_DYN][T_IDENTIFIER][T_ASSIGN][T_IDENTIFIER][T_ADD][T_IDENTIFIER]
#[T_IDENTIFIER][T_ASSIGN][T_IDENTIFIER]

#[T_DEF][T_INIT][T_LPAREN][T_RPAREN][T_COLON]
#[T_IDENTIFIER][T_LPAREN][T_STRING_LITERAL][T_RPAREN]
